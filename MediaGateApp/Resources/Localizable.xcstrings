          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate miễn phí và mã nguồn mở. Nếu bạn thấy hữu ích, một tip sẽ giúp duy trì phát triển."
          }
        },
        "zh-Hans" : {
