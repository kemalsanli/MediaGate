    "MediaGate" : {

    },
    "MediaGate is free and open source. If you find it useful, a tip helps keep development going." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate مجاني ومفتوح المصدر. إذا وجدته مفيدًا، فإن الإكرامية تساعد في استمرار التطوير."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate és gratuït i de codi obert. Si el trobeu útil, una propina ajuda a continuar el desenvolupament."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate je zdarma a open source. Pokud vám pomáhá, příspěvek pomůže pokračovat ve vývoji."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate er gratis og open source. Hvis du finder den nyttig, hjælper et drikkepenge med at holde udviklingen i gang."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate ist kostenlos und quelloffen. Wenn du es nützlich findest, hilft ein Trinkgeld, die Entwicklung fortzusetzen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το MediaGate είναι δωρεάν και ανοιχτού κώδικα. Αν το βρίσκετε χρήσιμο, ένα φιλοδώρημα βοηθά στη συνέχιση της ανάπτυξης."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate es gratuito y de código abierto. Si te resulta útil, una propina ayuda a continuar el desarrollo."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate es gratuito y de código abierto. Si te resulta útil, una propina ayuda a continuar el desarrollo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate on ilmainen ja avoimen lähdekoodin sovellus. Jos pidät sitä hyödyllisenä, tippi auttaa kehityksen jatkumista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate est gratuit et open source. Si vous le trouvez utile, un pourboire aide à poursuivre le développement."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate est gratuit et open source. Si vous le trouvez utile, un pourboire aide à poursuivre le développement."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate הוא חינמי וקוד פתוח. אם אתה מוצא אותו שימושי, טיפ עוזר להמשיך את הפיתוח."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate मुफ़्त और ओपन सोर्स है। अगर आपको यह उपयोगी लगे, तो एक टिप विकास जारी रखने में मदद करती है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate je besplatan i otvorenog koda. Ako vam je koristan, napojnica pomaže nastavku razvoja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A MediaGate ingyenes és nyílt forráskódú. Ha hasznosnak találod, a borravaló segít a fejlesztés folytatásában."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate gratis dan open source. Jika Anda merasa berguna, tip membantu pengembangan tetap berlanjut."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate è gratuito e open source. Se lo trovi utile, una mancia aiuta a continuare lo sviluppo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGateは無料のオープンソースです。便利だと感じたら、チップが開発の継続に役立ちます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate는 무료 오픈소스입니다. 유용하다고 생각하시면 팁이 개발을 계속하는 데 도움이 됩니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate adalah percuma dan sumber terbuka. Jika anda mendapatinya berguna, tip membantu pembangunan diteruskan."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate er gratis og åpen kildekode. Hvis du synes det er nyttig, hjelper et tips med å holde utviklingen i gang."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate is gratis en open source. Als je het nuttig vindt, helpt een fooi om de ontwikkeling voort te zetten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate jest darmowy i open source. Jeśli uważasz go za przydatny, napiwek pomaga kontynuować rozwój."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O MediaGate é gratuito e de código aberto. Se você achar útil, uma gorjeta ajuda a manter o desenvolvimento."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O MediaGate é gratuito e de código aberto. Se o considerar útil, uma gorjeta ajuda a manter o desenvolvimento."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate este gratuit și open source. Dacă îl găsiți util, un bacșiș ajută la continuarea dezvoltării."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate — бесплатное приложение с открытым исходным кодом. Если оно вам полезно, чаевые помогут продолжить разработку."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate je zadarmo a s otvoreným zdrojovým kódom. Ak vám pomáha, príspevok pomôže pokračovať vo vývoji."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate är gratis och öppen källkod. Om du tycker att det är användbart hjälper en dricks till att hålla utvecklingen igång."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MediaGate เป็นแอปฟรีและโอเพนซอร์ส หากคุณพบว่ามีประโยชน์ ทิปจะช่วยให้การพัฒนาดำเนินต่อไป"
